# ============================================================
# .env.example — Environment variable template
# ============================================================
# HOW TO USE:
#   cp .env.example .env
#   Fill in all values below with your own credentials.
#   NEVER commit .env — it is listed in .gitignore.
#
# docker-compose.yml reads these values at container startup.

# ── Database credentials ──────────────────────────────────────
# These are used by both the MySQL container and the backend API.
DB_NAME=epicbook_db
DB_USER=<your-db-username>
DB_PASSWORD=<your-strong-password>
DB_ROOT_PASSWORD=<your-strong-root-password>

# ── Application settings ──────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── JWT secret ────────────────────────────────────────────────
# Used to sign authentication tokens. Use a random 32+ character string.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=<your-jwt-secret>
