# ============================================================
# .gitignore — Files that should NEVER be committed to this repo
# ============================================================

# ── Secrets and credentials ───────────────────────────────────
.env                    # Docker Compose environment variables (contains passwords)
.env.*                  # All env variants (.env.prod, .env.local, etc.)
!.env.example           # EXCEPTION: .env.example IS committed (it's a template)

terraform.tfvars        # Terraform variable values (may contain subscription IDs)
!terraform.tfvars.example  # EXCEPTION: the example template is committed

*.pem                   # AWS/Azure private key files
id_rsa                  # SSH private keys
id_rsa.*
*.key                   # Private key files
vpc-ids.env             # Generated by 08 scripts — contains live resource IDs

# Ansible Vault files containing real secrets
group_vars/vault.yml
host_vars/*/vault.yml

# ── Terraform generated files ─────────────────────────────────
**/.terraform/          # downloaded provider plugins (large, reproducible)
**/.terraform.lock.hcl  # can be committed but project keeps it out for simplicity
**/terraform.tfstate    # CRITICAL: never commit state — use remote backend
**/terraform.tfstate.backup

# ── Node.js ───────────────────────────────────────────────────
**/node_modules/        # install with npm ci — never commit
**/npm-debug.log*

# ── Build artifacts ───────────────────────────────────────────
**/build/
**/dist/
**/.next/

# ── OS and IDE ────────────────────────────────────────────────
.DS_Store               # macOS directory metadata
Thumbs.db               # Windows thumbnail cache
.idea/                  # JetBrains IDE settings
.vscode/settings.json   # personal VS Code settings (workspace settings are fine)
*.swp                   # Vim swap files

# ── Docker ────────────────────────────────────────────────────
# (docker-compose.yml and Dockerfiles are intentionally committed)
